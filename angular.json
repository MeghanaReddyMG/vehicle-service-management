{
  "version": 1,
  "newProjectRoot": "projects",
  "projects": {
    "vms-angular": {
      "projectType": "application",
      "root": "",
      "sourceRoot": "src",
      "prefix": "app",
      "architect": {
        "build": {
          "builder": "@angular-devkit/build-angular:application",
          "options": {
            "outputPath": "dist/vms-angular",
            "index": "src/index.html",
            "browser": "src/main.ts",
            "polyfills": [
              "zone.js"
            ],
            "tsConfig": "tsconfig.json",
            "styles": [
              "src/styles.css"
            ],
            "scripts": [],
            "assets": []
          },
          "configurations": {
            "production": {
              "outputHashing": "all"
            },
            "development": {
              "optimization": false,
              "sourceMap": true
            }
          },
          "defaultConfiguration": "production"
        },
        "serve": {
          "builder": "@angular-devkit/build-angular:dev-server",
          "configurations": {
            "production": {
              "buildTarget": "vms-angular:build:production"
            },
            "development": {
              "buildTarget": "vms-angular:build:development"
            }
          },
          "defaultConfiguration": "development"
        }
      }
    }
  }
}